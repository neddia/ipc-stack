# Dev overrides (bind-mount setpoint)
ENV_FILE=.env.dev
SITE_AGENT_IMAGE=ghcr.io/neddia/site-agent
SITE_AGENT_VERSION=latest
GATEWAYD_IMAGE=ghcr.io/neddia/gatewayd
GATEWAYD_VERSION=latest

SETPOINT_UI_PORT=8000

# Point storage at the local setpoint repo for dev.
IPC_STORAGE_DIR=../setpoint/storage
IPC_SECRETS_DIR=../ipc-secrets

SITE_AGENT_UID=1000
SITE_AGENT_GID=1000

INFLUX_URL=http://influxdb:8086
INFLUX_BOOTSTRAP_URL=http://127.0.0.1:8086
INFLUX_ORG=edge-org
INFLUX_BUCKET=edge-site
INFLUX_RETENTION=30d
TELEGRAF_BUCKET=telegraf
TELEGRAF_RETENTION=14d
TELEGRAF_CONF=telegraf.dev.conf


ENABLE_SIM=1 


LOG_LEVEL=INFO
SITE_CONFIG_PATH=/app/storage/site-config.yml
PROFILES_DIR=/app/storage/profiles

EDGE_TCP_PORT=3333
CLOUD_TIMEOUT_SECONDS=3
OPTIMIZER_LICENSE_POLICY=required
IPC_IDENTITY_PATH=/app/storage/ipc/identity.json

GATEWAYD_HY_TRACE=1

IPC_PUBLIC_KEY_FILE=/run/secrets/ipc_ed25519.pub

IPC_PRIVATE_KEY_FILE=/run/secrets/ipc_ed25519

# Public key used by site-agent to verify cloud-signed optimizer licenses.
# Populate ../ipc-secrets/cloud.license.ed25519.pub with the matching cloud key.
CLOUD_LICENSE_SIGNING_PUBLIC_KEY_FILE=/run/secrets/cloud.license.ed25519.pub

TAILSCALE_IP=100.68.88.64

# CLOUD_BASE_URL=http://192.168.77.215:8001
CLOUD_BASE_URL=https://toopscontrols.com
# or if using direct VM API port:
# CLOUD_BASE_URL=http://<cloud-tailnet-ip>:8001
HARDWARE_SERIAL=local-wsl-site-agent-01
EDGE_ALERT_EVAL_EVERY_S=90